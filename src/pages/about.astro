---
import Layout from '../layouts/Layout.astro';
import DataDisclaimer from '../components/DataDisclaimer.astro';
import AdSlot from '../components/AdSlot.astro';
---

<Layout
  title="About Us — World Companies by Market Cap"
  description="Learn about World Companies by Market Cap, the independent financial data platform tracking the largest public corporations and ETFs worldwide."
>
  <DataDisclaimer />

  <div class="max-w-[1000px] mx-auto px-4 py-12 space-y-10">
    <div class="space-y-3">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 text-blue-600 dark:text-blue-400 text-xs font-semibold">
        <span>🌐 Global Equity Analytics</span>
        <span>•</span>
        <span>Independent Research</span>
      </div>

      <h1 class="text-3xl md:text-5xl font-black tracking-tight text-[var(--color-text-primary)]">
        About World Companies by Market Cap
      </h1>
      <p class="text-base text-[var(--color-text-secondary)] leading-relaxed">
        We track the largest publicly traded companies, state-owned enterprises, and exchange-traded funds (ETFs) by market value across global stock markets.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] space-y-2">
        <div class="text-2xl">📊</div>
        <h3 class="text-base font-bold text-[var(--color-text-primary)]">Global Coverage</h3>
        <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">
          Tracking companies from 20+ countries across North America, Europe, Asia-Pacific, Latin America, and Middle East.
        </p>
      </div>

      <div class="p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] space-y-2">
        <div class="text-2xl">⚡</div>
        <h3 class="text-base font-bold text-[var(--color-text-primary)]">Sub-Second SSR</h3>
        <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">
          Built on AstroJS and Cloudflare Workers edge architecture for instant static load times worldwide.
        </p>
      </div>

      <div class="p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] space-y-2">
        <div class="text-2xl">🔒</div>
        <h3 class="text-base font-bold text-[var(--color-text-primary)]">Privacy First</h3>
        <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">
          Zero user tracking or login required. All personal watchlists and preferences stored locally in your browser.
        </p>
      </div>
    </div>

    <AdSlot variant="banner" />
  </div>
</Layout>
