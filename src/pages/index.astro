---
import Layout from '../layouts/Layout.astro';
import DataDisclaimer from '../components/DataDisclaimer.astro';
import AdSlot from '../components/AdSlot.astro';
import { CompanyLogo } from '../components/react/CompanyLogo';
import { getAllCompanies, getTopMovers } from '../lib/data';
import { formatLargeNumber, formatPercent, getCountryFlag } from '../lib/format';

const companies = getAllCompanies();
const totalMarketCap = companies.reduce((acc, c) => acc + c.marketCap, 0);
const gainers = getTopMovers('gainers', 5);
const losers = getTopMovers('losers', 5);
const top50 = companies.slice(0, 10);
---

<Layout title="World Companies by Market Cap — Global Stock Rankings & Intelligence">
  <DataDisclaimer />

  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 px-4 bg-gradient-to-b from-[var(--color-bg-alt)] to-[var(--color-bg)] border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto text-center space-y-6">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 text-blue-600 dark:text-blue-400 text-xs font-semibold border border-blue-500/20">
        <span>🌐 Global Market Intelligence</span>
        <span>•</span>
        <span>100+ Tracked Entities</span>
      </div>

      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-[var(--color-text-primary)]">
        World Companies by <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-sky-400">Market Cap</span>
      </h1>

      <p class="text-base md:text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto leading-relaxed">
        Track global market capitalizations, earnings, revenues, employees, P/E ratios, and financial metrics across public equities and ETFs.
      </p>

      {/* Global Market Cap Counter Badge */}
      <div class="pt-4 flex flex-wrap items-center justify-center gap-6">
        <div class="p-4 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)] min-w-[200px] shadow-xs">
          <div class="text-xs text-[var(--color-text-muted)] font-mono uppercase font-semibold">Total Global Market Cap</div>
          <div class="text-2xl md:text-3xl font-black text-blue-600 dark:text-blue-400 font-mono mt-1">
            {formatLargeNumber(totalMarketCap)}
          </div>
        </div>

        <div class="p-4 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)] min-w-[200px] shadow-xs">
          <div class="text-xs text-[var(--color-text-muted)] font-mono uppercase font-semibold">Top Entity</div>
          <div class="text-xl md:text-2xl font-bold text-[var(--color-text-primary)] mt-1 flex items-center justify-center gap-2">
            <span>{companies[0].name}</span>
            <span class="text-xs font-mono text-emerald-500">{formatLargeNumber(companies[0].marketCap)}</span>
          </div>
        </div>
      </div>

      <!-- Quick Action Buttons -->
      <div class="pt-4 flex items-center justify-center gap-4">
        <a
          href="/ranking/global"
          class="px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm shadow-md transition-all scale-100 hover:scale-105"
        >
          View Full Rankings →
        </a>
        <a
          href="/etfs"
          class="px-6 py-3 rounded-xl bg-[var(--color-surface)] hover:bg-[var(--color-surface-hover)] border border-[var(--color-border)] text-[var(--color-text-primary)] font-bold text-sm transition-all"
        >
          Explore ETFs
        </a>
      </div>
    </div>
  </section>

  <!-- Hero AdSlot -->
  <AdSlot variant="banner" />

  <!-- Today's Top Movers Strip -->
  <section class="max-w-[1440px] mx-auto px-4 py-10 space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-xl md:text-2xl font-bold text-[var(--color-text-primary)]">Today's Top Market Movers</h2>
        <p class="text-xs text-[var(--color-text-secondary)]">24-hour largest gainers and losers in global equities</p>
      </div>
      <a href="/movers" class="text-xs font-semibold text-blue-600 dark:text-blue-400 hover:underline">
        View All Movers →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {/* Top Gainers Card */}
      <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] space-y-4">
        <div class="flex items-center justify-between pb-3 border-b border-[var(--color-border)]">
          <span class="font-bold text-sm text-emerald-600 dark:text-emerald-400 flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span> Top Gainers (24h)
          </span>
          <span class="text-xs font-mono text-[var(--color-text-muted)]">+% Change</span>
        </div>

        <div class="space-y-2.5">
          {gainers.map(c => (
            <a href={`/companies/${c.ticker.toLowerCase()}`} class="flex items-center justify-between p-2 rounded-lg hover:bg-[var(--color-surface)] transition-colors group">
              <div class="flex items-center gap-3">
                <CompanyLogo ticker={c.ticker} domain={c.domain} name={c.name} size={32} />
                <div>
                  <div class="font-bold text-sm text-[var(--color-text-primary)] group-hover:underline">{c.name}</div>
                  <div class="text-xs text-[var(--color-text-secondary)] font-mono">{c.ticker} • {getCountryFlag(c.countryCode)}</div>
                </div>
              </div>
              <div class="text-right font-mono">
                <div class="font-bold text-emerald-500 text-sm">{formatPercent(c.priceChange1D)}</div>
                <div class="text-xs text-[var(--color-text-muted)]">${c.price}</div>
              </div>
            </a>
          ))}
        </div>
      </div>

      {/* Top Losers Card */}
      <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] space-y-4">
        <div class="flex items-center justify-between pb-3 border-b border-[var(--color-border)]">
          <span class="font-bold text-sm text-rose-600 dark:text-rose-400 flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-rose-500"></span> Top Losers (24h)
          </span>
          <span class="text-xs font-mono text-[var(--color-text-muted)]">-% Change</span>
        </div>

        <div class="space-y-2.5">
          {losers.map(c => (
            <a href={`/companies/${c.ticker.toLowerCase()}`} class="flex items-center justify-between p-2 rounded-lg hover:bg-[var(--color-surface)] transition-colors group">
              <div class="flex items-center gap-3">
                <CompanyLogo ticker={c.ticker} domain={c.domain} name={c.name} size={32} />
                <div>
                  <div class="font-bold text-sm text-[var(--color-text-primary)] group-hover:underline">{c.name}</div>
                  <div class="text-xs text-[var(--color-text-secondary)] font-mono">{c.ticker} • {getCountryFlag(c.countryCode)}</div>
                </div>
              </div>
              <div class="text-right font-mono">
                <div class="font-bold text-rose-500 text-sm">{formatPercent(c.priceChange1D)}</div>
                <div class="text-xs text-[var(--color-text-muted)]">${c.price}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Major Indices Overview Cards -->
  <section class="max-w-[1440px] mx-auto px-4 py-6">
    <h2 class="text-lg font-bold text-[var(--color-text-primary)] mb-4">Global Stock Indices</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {[
        { name: 'S&P 500', value: '5,524.30', change: '+0.35%', positive: true, country: '🇺🇸' },
        { name: 'NASDAQ', value: '17,842.10', change: '+0.82%', positive: true, country: '🇺🇸' },
        { name: 'Nifty 50', value: '24,541.20', change: '+0.45%', positive: true, country: '🇮🇳' },
        { name: 'FTSE 100', value: '8,190.50', change: '-0.18%', positive: false, country: '🇬🇧' },
        { name: 'Nikkei 225', value: '38,210.00', change: '-0.42%', positive: false, country: '🇯🇵' }
      ].map(idx => (
        <div class="p-3.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] shadow-xs">
          <div class="flex items-center justify-between text-xs text-[var(--color-text-secondary)] font-semibold">
            <span>{idx.country} {idx.name}</span>
            <span class={idx.positive ? 'text-emerald-500 font-mono' : 'text-rose-500 font-mono'}>{idx.change}</span>
          </div>
          <div class="text-base font-bold font-mono text-[var(--color-text-primary)] mt-1">{idx.value}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Top 10 Preview Table -->
  <section class="max-w-[1440px] mx-auto px-4 py-10 space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="text-xl font-bold text-[var(--color-text-primary)]">Top 10 Global Companies</h2>
      <a href="/ranking/global" class="text-xs font-semibold text-blue-600 dark:text-blue-400 hover:underline">
        Open Master Rank Engine (100+) →
      </a>
    </div>

    <div class="overflow-x-auto rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] shadow-xs">
      <table class="w-full text-left border-collapse text-sm">
        <thead>
          <tr class="bg-[var(--color-bg-alt)] border-b border-[var(--color-border)] text-xs text-[var(--color-text-secondary)] font-semibold">
            <th class="py-3 px-3 w-12 text-center">Rank</th>
            <th class="py-3 px-3">Company</th>
            <th class="py-3 px-3 text-right">Market Cap</th>
            <th class="py-3 px-3 text-right">Price</th>
            <th class="py-3 px-3 text-right">24h %</th>
            <th class="py-3 px-3 text-center">Country</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--color-border-subtle)]">
          {top50.map(c => (
            <tr class="hover:bg-[var(--color-surface)] transition-colors">
              <td class="py-3 px-3 text-center font-mono text-xs text-[var(--color-text-muted)]">#{c.rank}</td>
              <td class="py-3 px-3">
                <a href={`/companies/${c.ticker.toLowerCase()}`} class="flex items-center gap-3 hover:underline">
                  <CompanyLogo ticker={c.ticker} domain={c.domain} name={c.name} size={32} />
                  <div>
                    <div class="font-bold text-[var(--color-text-primary)]">{c.name}</div>
                    <div class="text-xs text-[var(--color-text-secondary)] font-mono">{c.ticker}</div>
                  </div>
                </a>
              </td>
              <td class="py-3 px-3 text-right font-mono font-bold text-blue-600 dark:text-blue-400">
                {formatLargeNumber(c.marketCap)}
              </td>
              <td class="py-3 px-3 text-right font-mono text-xs text-[var(--color-text-secondary)]">
                ${c.price}
              </td>
              <td class={`py-3 px-3 text-right font-mono text-xs font-semibold ${c.priceChange1D >= 0 ? 'text-emerald-500' : 'text-rose-500'}`}>
                {formatPercent(c.priceChange1D)}
              </td>
              <td class="py-3 px-3 text-center text-base" title={c.country}>
                {getCountryFlag(c.countryCode)}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
