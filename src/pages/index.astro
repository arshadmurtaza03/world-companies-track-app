---
import Layout from '../layouts/Layout.astro';
import DataDisclaimer from '../components/DataDisclaimer.astro';
import AdSlot from '../components/AdSlot.astro';
import RankingTable from '../components/react/RankingTable';
import { getAllCompanies } from '../lib/data';
import { formatLargeNumber } from '../lib/format';

const companies = getAllCompanies();
const totalMarketCap = companies.reduce((acc, c) => acc + c.marketCap, 0);
---

<Layout title="Largest Companies by Market Cap — World Companies">
  <DataDisclaimer />

  <div class="max-w-[1440px] mx-auto px-4 py-6 space-y-6">
    <!-- Header Title Section (Competitor Hierarchy) -->
    <div class="text-center space-y-2 py-4">
      <h1 class="text-3xl md:text-5xl font-black tracking-tight text-[var(--color-text-primary)]">
        Largest Companies by Marketcap
      </h1>
      <p class="text-xs md:text-sm text-[var(--color-text-secondary)] font-mono">
        Companies: <strong class="text-[var(--color-text-primary)]">{companies.length}</strong> &nbsp;•&nbsp; total market cap: <strong class="text-[var(--color-text-primary)]">{formatLargeNumber(totalMarketCap)}</strong>
      </p>
    </div>

    <AdSlot variant="banner" />

    <!-- Hero Product: Core Ranking Table -->
    <section>
      <RankingTable client:load companies={companies} />
    </section>

    <AdSlot variant="banner" />
  </div>
</Layout>
