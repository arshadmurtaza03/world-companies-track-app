---
import Layout from '../../layouts/Layout.astro';
import DataDisclaimer from '../../components/DataDisclaimer.astro';
import AdSlot from '../../components/AdSlot.astro';
import SectorTreemap from '../../components/react/SectorTreemap';
import { getUniqueSectors, getAllCompanies } from '../../lib/data';
import { formatLargeNumber } from '../../lib/format';

const sectors = getUniqueSectors();
const totalGlobalCap = getAllCompanies().reduce((sum, c) => sum + c.marketCap, 0);
---

<Layout
  title="Market Weightings & Rankings by Sector — World Companies Directory"
  description="Interactive sector market cap weightings and rankings. Analyze Technology, Financials, Energy, Healthcare, Consumer Cyclicals, and all global sectors."
>
  <DataDisclaimer />

  <div class="max-w-[1440px] mx-auto px-4 py-8 space-y-10">
    <div class="space-y-2">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 text-blue-600 dark:text-blue-400 text-xs font-semibold">
        <span>📊 Sector Distribution</span>
        <span>•</span>
        <span>{sectors.length} Market Sectors</span>
      </div>

      <h1 class="text-3xl md:text-4xl font-black tracking-tight text-[var(--color-text-primary)]">
        Public Companies by Industry Sector
      </h1>
      <p class="text-sm text-[var(--color-text-secondary)] max-w-2xl">
        Explore global market cap weightings across major sectors. Hover over the interactive treemap or browse sector cards below.
      </p>
    </div>

    <!-- Interactive Sector Treemap Island -->
    <section>
      <SectorTreemap client:visible sectors={sectors} />
    </section>

    <!-- Sector Cards Grid -->
    <section class="space-y-4">
      <h2 class="text-xl font-bold text-[var(--color-text-primary)]">All Industry Sectors</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {sectors.map(s => {
          const percentShare = ((s.totalCap / totalGlobalCap) * 100).toFixed(1);
          const slug = s.name.toLowerCase().replace(/\s+/g, '-');

          return (
            <a
              href={`/sectors/${slug}`}
              class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:scale-[1.02] hover:border-blue-500 transition-all shadow-xs space-y-4 group"
            >
              <div class="flex items-center justify-between">
                <div>
                  <div class="font-bold text-base text-[var(--color-text-primary)] group-hover:text-blue-600 transition-colors">
                    {s.name}
                  </div>
                  <div class="text-xs text-[var(--color-text-muted)] font-mono">{s.count} Companies</div>
                </div>
                <span class="text-xs font-mono font-bold text-blue-600 dark:text-blue-400 bg-blue-500/10 px-2.5 py-1 rounded-md">
                  {percentShare}% Share
                </span>
              </div>

              <div class="pt-3 border-t border-[var(--color-border-subtle)] flex items-center justify-between text-xs font-mono">
                <span class="text-[var(--color-text-secondary)]">Total Market Value:</span>
                <span class="font-bold text-[var(--color-text-primary)]">{formatLargeNumber(s.totalCap)}</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <AdSlot variant="banner" />
  </div>
</Layout>
