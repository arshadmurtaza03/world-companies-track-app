---
import { ThemeToggle } from './react/ThemeToggle';
import { CurrencySwitcher } from './react/CurrencySwitcher';
import HeaderSearch from './react/HeaderSearch';
import { getAllCompanies } from '../lib/data';
import { formatLargeNumber } from '../lib/format';

const companies = getAllCompanies();
const totalMarketCap = companies.reduce((acc, c) => acc + c.marketCap, 0);
---

<header class="sticky top-0 z-40 w-full font-sans">
  <!-- Top Mini Utility Bar (Competitor-aligned black/dark bar with dynamic dataset stats) -->
  <div class="bg-slate-950 text-slate-300 text-[11px] font-mono py-1 px-4 border-b border-slate-800">
    <div class="max-w-[1440px] mx-auto flex items-center justify-between gap-4">
      <div class="flex items-center gap-2 truncate">
        <span>Companies: <strong class="text-white font-bold">{companies.length}</strong></span>
        <span class="text-slate-600">•</span>
        <span>total market cap: <strong class="text-amber-400 font-bold">{formatLargeNumber(totalMarketCap)}</strong></span>
      </div>

      <div class="flex items-center gap-3 shrink-0">
        <button class="hover:text-white transition-colors cursor-pointer hidden sm:inline">Sign In</button>
        <span class="text-slate-600 hidden sm:inline">•</span>
        <span class="hover:text-white transition-colors cursor-pointer hidden sm:inline">🇺🇸 English ▾</span>
        <span class="text-slate-600 hidden sm:inline">•</span>
        <CurrencySwitcher client:load />
        <span class="text-slate-600">•</span>
        <ThemeToggle client:load />
      </div>
    </div>
  </div>

  <!-- Main Navbar -->
  <div class="backdrop-blur-md bg-[var(--color-navbar-bg)] border-b border-[var(--color-navbar-border)] transition-colors">
    <div class="max-w-[1440px] mx-auto px-4 h-13 flex items-center justify-between gap-4">
      <!-- Brand Logo + Main Nav Links -->
      <div class="flex items-center gap-6">
        <a href="/" class="flex items-center gap-2 group shrink-0">
          <!-- Competitor-style Orange Bar Chart Icon -->
          <div class="w-6 h-6 rounded bg-amber-500 flex items-end justify-center p-1 gap-0.5 shadow-xs">
            <span class="w-1 bg-white rounded-t h-2"></span>
            <span class="w-1 bg-white rounded-t h-4"></span>
            <span class="w-1 bg-white rounded-t h-3"></span>
          </div>
          <span class="font-bold text-sm text-[var(--color-text-primary)] tracking-tight group-hover:text-amber-500 transition-colors">
            Global ranking
          </span>
        </a>

        <!-- Category Dropdown Links -->
        <nav class="hidden lg:flex items-center gap-4 text-xs font-semibold text-[var(--color-text-secondary)]">
          <a href="/countries" class="hover:text-[var(--color-text-primary)] transition-colors flex items-center gap-1">
            Ranking by countries ▾
          </a>
          <a href="/sectors" class="hover:text-[var(--color-text-primary)] transition-colors flex items-center gap-1">
            Ranking by categories ▾
          </a>
          <a href="/etfs" class="hover:text-[var(--color-text-primary)] transition-colors flex items-center gap-1">
            ETFs ▾
          </a>
          <a href="/watchlist" class="hover:text-[var(--color-text-primary)] transition-colors flex items-center gap-1">
            ★ Watchlist
          </a>
        </nav>
      </div>

      <!-- Right Side: Visible Instant Header Search -->
      <div class="flex items-center gap-3">
        <HeaderSearch client:load companies={companies} />
      </div>
    </div>
  </div>
</header>
